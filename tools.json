[
    {
        "name": "aws_cloud_control",
        "description": "Execute AWS Cloud Control API operations for infrastructure management",
        "schema": {
            "type": "object",
            "properties": {
                "operation": {
                    "type": "string",
                    "enum": ["create", "read", "update", "delete", "list"],
                    "description": "The operation to perform"
                },
                "resource_type": {
                    "type": "string",
                    "description": "AWS resource type (e.g., AWS::S3::Bucket, AWS::EC2::Instance)"
                },
                "identifier": {
                    "type": "string",
                    "description": "Resource identifier for read/update/delete operations"
                },
                "properties": {
                    "type": "object",
                    "description": "Resource properties for create/update operations"
                },
                "region": {
                    "type": "string",
                    "description": "AWS region for the operation (default: eu-north-1)"
                }
            },
            "required": ["operation", "resource_type"]
        }
    },
    {
        "name": "cloudwatch_logs",
        "description": "Query CloudWatch Logs for Lambda function error logs",
        "schema": {
            "type": "object",
            "properties": {
                "function_name": {
                    "type": "string",
                    "description": "Name of the Lambda function to check for errors"
                },
                "hours_back": {
                    "type": "integer",
                    "description": "Number of hours to look back for errors (default: 1)"
                }
            },
            "required": ["function_name"]
        }
    },
    {
        "name": "ecs_clusters",
        "description": "List and describe ECS clusters in AWS",
        "schema": {
            "type": "object",
            "properties": {
                "operation": {
                    "type": "string",
                    "enum": ["list", "describe"],
                    "description": "Operation to perform: list all clusters or describe specific clusters"
                },
                "cluster_names": {
                    "type": "array",
                    "items": {"type": "string"},
                    "description": "List of cluster names/ARNs to describe (required for describe operation)"
                },
                "region": {
                    "type": "string",
                    "description": "AWS region (default: eu-north-1)"
                }
            },
            "required": ["operation"]
        }
    }
]
